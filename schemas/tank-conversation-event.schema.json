{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tank.romaine.life/schemas/tank-conversation-event.schema.json",
  "title": "Tank Conversation Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "session_id",
    "actor",
    "source",
    "type",
    "created_at",
    "order_key",
    "visibility"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "uuid": {
      "description": "Runner-stamped id used for live/history dedupe. For Tank events this normally matches event_id.",
      "type": "string",
      "minLength": 1
    },
    "id": {
      "description": "Session-events document id when a persisted event is returned by /timeline.",
      "type": "string",
      "minLength": 1
    },
    "order_key": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "tank_turn_seq": {
      "description": "Codex-runner local turn sequence stamped on some events for turn correlation.",
      "type": "integer",
      "minimum": 1
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "tank_session_id": {
      "description": "Session-events partition key when a persisted event is returned by /timeline.",
      "type": "string",
      "minLength": 1
    },
    "email": {
      "description": "Owner email stamped on persisted session-events documents.",
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": "string",
      "minLength": 1
    },
    "timeline_id": {
      "description": "Tank-owned durable identity for a renderable timeline entry. Provider IDs must not be used as UI identity.",
      "type": "string",
      "minLength": 1
    },
    "provider_item_id": {
      "description": "Raw provider-scoped item id, preserved as metadata only.",
      "type": "string",
      "minLength": 1
    },
    "parent_id": {
      "type": "string",
      "minLength": 1
    },
    "client_nonce": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "enum": ["user", "assistant", "system", "tool", "runner"]
    },
    "source": {
      "type": "string",
      "enum": ["tank", "claude", "codex"]
    },
    "type": {
      "type": "string",
      "enum": [
        "conversation.started",
        "conversation.archived",
        "user_message.created",
        "turn.submitted",
        "turn.started",
        "turn.completed",
        "turn.failed",
        "turn.interrupted",
        "item.started",
        "item.delta",
        "item.completed",
        "item.failed",
        "tool.approval_requested",
        "tool.approval_resolved",
        "session.activity_updated",
        "read_state.updated"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "written_at": {
      "description": "Runner/storage write timestamp stamped before the Cosmos write.",
      "type": "string",
      "format": "date-time"
    },
    "runtime": {
      "description": "Session-events storage runtime stamp.",
      "type": "string",
      "enum": ["claude", "codex"]
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "runtime": { "type": "string" },
        "provider_event_id": { "type": "string" }
      }
    },
    "visibility": {
      "type": "string",
      "enum": ["durable", "live-only", "audit-only"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "_rid": {
      "description": "Cosmos DB system property that may be present on persisted timeline documents.",
      "type": "string",
      "minLength": 1
    },
    "_self": {
      "description": "Cosmos DB system property that may be present on persisted timeline documents.",
      "type": "string",
      "minLength": 1
    },
    "_etag": {
      "description": "Cosmos DB system property that may be present on persisted timeline documents.",
      "type": "string",
      "minLength": 1
    },
    "_attachments": {
      "description": "Cosmos DB system property that may be present on persisted timeline documents.",
      "type": "string",
      "minLength": 1
    },
    "_ts": {
      "description": "Cosmos DB system property that may be present on persisted timeline documents.",
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "userMessagePayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["text", "display"],
      "properties": {
        "text": { "$ref": "#/$defs/nonEmptyString" },
        "message": {},
        "display": {
          "oneOf": [
            { "$ref": "#/$defs/plainUserDisplay" },
            { "$ref": "#/$defs/skillInvocationDisplay" }
          ]
        }
      }
    },
    "plainUserDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "const": "plain" }
      }
    },
    "skillInvocationDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "skill_name"],
      "properties": {
        "kind": { "const": "skill_invocation" },
        "skill_name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "supplemental_text": { "type": "string" }
      }
    },
    "statusPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status"],
      "properties": {
        "status": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "itemPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind"],
      "properties": {
        "kind": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "readStatePayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["last_read_order_key"],
      "properties": {
        "last_read_order_key": { "$ref": "#/$defs/nonEmptyString" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "user_message.created" } }, "required": ["type"] },
      "then": {
        "required": ["turn_id", "timeline_id", "client_nonce", "payload"],
        "properties": {
          "actor": { "const": "user" },
          "source": { "const": "tank" },
          "payload": { "$ref": "#/$defs/userMessagePayload" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "turn.submitted" } }, "required": ["type"] },
      "then": {
        "required": ["turn_id", "client_nonce", "payload"],
        "properties": {
          "actor": { "const": "runner" },
          "source": { "const": "tank" },
          "payload": { "$ref": "#/$defs/statusPayload" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["turn.started", "turn.completed", "turn.failed", "turn.interrupted"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["turn_id"],
        "properties": {
          "actor": { "const": "runner" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["item.started", "item.delta", "item.completed", "item.failed"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["turn_id", "timeline_id", "payload"],
        "properties": {
          "payload": { "$ref": "#/$defs/itemPayload" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["tool.approval_requested", "tool.approval_resolved"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["turn_id", "timeline_id", "payload"],
        "properties": {
          "actor": { "const": "tool" },
          "payload": { "$ref": "#/$defs/itemPayload" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "session.activity_updated" } }, "required": ["type"] },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": { "$ref": "#/$defs/statusPayload" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "read_state.updated" } }, "required": ["type"] },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": { "$ref": "#/$defs/readStatePayload" }
        }
      }
    }
  ]
}
