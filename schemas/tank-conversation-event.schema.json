{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tank.romaine.life/schemas/tank-conversation-event.schema.json",
  "title": "Tank Conversation Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "session_id",
    "actor",
    "source",
    "type",
    "created_at",
    "order_key",
    "visibility"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "uuid": {
      "description": "Runner-stamped id used for live/history dedupe. For Tank events this normally matches event_id.",
      "type": "string",
      "minLength": 1
    },
    "id": {
      "description": "Session-events document id when a persisted event is returned by /timeline.",
      "type": "string",
      "minLength": 1
    },
    "order_key": {
      "type": "string",
      "minLength": 1
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "tank_turn_seq": {
      "description": "Codex-runner local turn sequence stamped on some events for turn correlation.",
      "type": "integer",
      "minimum": 1
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "tank_session_id": {
      "description": "Session-events partition key when a persisted event is returned by /timeline.",
      "type": "string",
      "minLength": 1
    },
    "email": {
      "description": "Owner email stamped on persisted session-events documents.",
      "type": "string",
      "minLength": 1
    },
    "origin_session_id": {
      "description": "When a user-role message was authored by a sibling tank-operator session (via the mcp-tank-operator send_prompt / spawn_run_session tools) rather than typed by the human owner, this carries the originating session id. The frontend renders the user bubble with the parent session's deterministic avatar instead of the human's Gravatar so cross-session handoffs read as agent-authored, not user-authored. Owner attribution stays on `email` — both the human owner and the spawning session are owned by the same human. Empty/absent for normal human-typed turns.",
      "type": "string",
      "minLength": 1
    },
    "origin_session_avatar_id": {
      "description": "Assigned agent avatar id for origin_session_id. This is stamped when the originating session is outside the target session list scope, such as a production session spawning a Glimmung test-slot session, so the frontend can render the same avatar without needing to load the origin session row.",
      "type": "string",
      "minLength": 1
    },
    "turn_id": {
      "type": "string",
      "minLength": 1
    },
    "timeline_id": {
      "description": "Tank-owned durable identity for a renderable timeline entry. Provider IDs must not be used as UI identity.",
      "type": "string",
      "minLength": 1
    },
    "provider_item_id": {
      "description": "Raw provider-scoped item id, preserved as metadata only.",
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "description": "Provider or Tank task identifier for session-level background shell tasks.",
      "type": "string",
      "minLength": 1
    },
    "parent_id": {
      "type": "string",
      "minLength": 1
    },
    "client_nonce": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "string",
      "enum": ["user", "assistant", "system", "tool", "runner"]
    },
    "source": {
      "type": "string",
      "enum": ["tank", "claude", "codex"]
    },
    "type": {
      "type": "string",
      "enum": [
        "user_message.created",
        "assistant_message.created",
        "turn.submitted",
        "turn.claimed",
        "turn.started",
        "turn.usage",
        "turn.completed",
        "turn.failed",
        "turn.command_failed",
        "turn.interrupt_requested",
        "turn.interrupted",
        "turn.input_answered",
        "context.compacted",
        "session.status",
        "item.started",
        "item.completed",
        "item.failed",
        "shell_task.started",
        "shell_task.updated",
        "shell_task.exited",
        "scheduled_wakeup.updated",
        "ci_status.updated",
        "test_provision.updated",
        "turn.awaiting_input",
        "turn.awaiting_input.invocation"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "written_at": {
      "description": "Runner/storage write timestamp stamped before the Cosmos write.",
      "type": "string",
      "format": "date-time"
    },
    "runtime": {
      "description": "Session-events storage runtime stamp.",
      "type": "string",
      "enum": ["claude", "codex"]
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "runtime": { "type": "string" },
        "provider_event_id": { "type": "string" }
      }
    },
    "visibility": {
      "description": "Tank conversation events are durable-by-design. `live-only` was retired once the producer-side live channel never landed; the enum is kept single-valued so callers still explicitly tag durability rather than infer it.",
      "type": "string",
      "enum": ["durable"]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "_rid": {
      "description": "Legacy Cosmos system property tolerated on documents migrated from the Cosmos session-events container so replay validates. New writes from the persister do not include these fields.",
      "type": "string",
      "minLength": 1
    },
    "_self": {
      "description": "Legacy Cosmos system property tolerated on migrated documents; see `_rid`.",
      "type": "string",
      "minLength": 1
    },
    "_etag": {
      "description": "Legacy Cosmos system property tolerated on migrated documents; see `_rid`.",
      "type": "string",
      "minLength": 1
    },
    "_attachments": {
      "description": "Legacy Cosmos system property tolerated on migrated documents; see `_rid`.",
      "type": "string",
      "minLength": 1
    },
    "_ts": {
      "description": "Legacy Cosmos system property tolerated on migrated documents; see `_rid`.",
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "userMessagePayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["text", "display"],
      "properties": {
        "text": { "$ref": "#/$defs/nonEmptyString" },
        "message": {},
        "display": {
          "oneOf": [
            { "$ref": "#/$defs/plainUserDisplay" },
            { "$ref": "#/$defs/skillInvocationDisplay" }
          ]
        },
        "attachments": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/userMessageAttachment" }
        }
      }
    },
    "assistantMessagePayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["text", "display"],
      "properties": {
        "text": { "$ref": "#/$defs/nonEmptyString" },
        "message": {},
        "display": {
          "type": "object",
          "additionalProperties": true,
          "required": ["kind"],
          "properties": {
            "kind": { "type": "string", "enum": ["plain", "ask_user_question"] }
          }
        },
        "awaiting_input": {
          "type": "object",
          "additionalProperties": true,
          "required": ["questions"],
          "properties": {
            "asking_turn_id": { "type": "string", "minLength": 1 },
            "question_turn_id": { "type": "string", "minLength": 1 },
            "provider_item_id": { "type": "string", "minLength": 1 },
            "timeline_id": { "type": "string", "minLength": 1 },
            "provider_timeline_id": { "type": "string", "minLength": 1 },
            "questions": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/askUserQuestion" }
            },
            "plan": { "type": "string" }
          }
        }
      }
    },
    "userMessageAttachment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "name", "kind"],
      "properties": {
        "label": { "$ref": "#/$defs/nonEmptyString" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "kind": { "enum": ["image", "file"] },
        "path": { "type": "string", "minLength": 1 },
        "absPath": { "type": "string", "minLength": 1 },
        "size": { "type": "number", "minimum": 0 }
      }
    },
    "plainUserDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "const": "plain" }
      }
    },
    "skillInvocationDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "skill_name"],
      "properties": {
        "kind": { "const": "skill_invocation" },
        "skill_name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,64}$"
        },
        "supplemental_text": { "type": "string" }
      }
    },
    "askUserQuestion": {
      "description": "Tank-canonical AskUserQuestion question shape. Both runner adapters normalize the provider question into this shape before publishing turn.awaiting_input; the frontend renders this shape only.",
      "type": "object",
      "additionalProperties": true,
      "required": ["question"],
      "properties": {
        "question": { "$ref": "#/$defs/nonEmptyString" },
        "header": { "type": "string" },
        "multiSelect": { "type": "boolean" },
        "allowFreeForm": { "type": "boolean" },
        "secret": { "type": "boolean" },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "label": { "type": "string" },
              "description": { "type": "string" },
              "preview": { "type": "string" }
            }
          }
        }
      }
    },
    "awaitingInputPayload": {
      "description": "Payload for turn.awaiting_input: the questions the agent asked while pausing the active turn, plus the AskUserQuestion item ids the answer endpoint targets.",
      "type": "object",
      "additionalProperties": true,
      "required": ["questions"],
      "properties": {
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/askUserQuestion" }
        },
        "plan": {
          "description": "ExitPlanMode plan markdown rendered on the question page above the Approve/Request-changes question. Absent for ordinary AskUserQuestion pauses.",
          "type": "string"
        },
        "asking_turn_final_answer": {
          "description": "Optional final-answer candidate from the asking turn at the moment the runner paused for AskUserQuestion. Uses the same shape as turn.completed.payload.final_answer so the question page can render the exact assistant item(s) the adapter considered final before the pause.",
          "$ref": "#/$defs/finalAnswer"
        },
        "provider_item_id": { "type": "string", "minLength": 1 },
        "timeline_id": { "type": "string", "minLength": 1 }
      }
    },
    "inputAnsweredPayload": {
      "description": "Payload for turn.input_answered: the user's durable answer to a question that paused the same active turn.",
      "type": "object",
      "additionalProperties": true,
      "required": ["question_timeline_id", "provider_item_id", "answers"],
      "properties": {
        "question_timeline_id": { "type": "string", "minLength": 1 },
        "provider_item_id": { "type": "string", "minLength": 1 },
        "answers": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "annotations": { "type": "object" }
      }
    },
    "statusPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status"],
      "properties": {
        "status": { "$ref": "#/$defs/nonEmptyString" },
        "source": {
          "description": "Optional payload-level provenance for backend-originated self-submit paths. The turn.submitted envelope source remains tank.",
          "enum": ["schedule-wakeup", "background-task", "launch-dispatch", "break-glass-approval", "test-slot-model-approval", "test-slot-drive", "orchestrate-launch"]
        },
        "prompt": {
          "description": "Optional backend-owned prompt text for self-submit paths whose user-facing message is not persisted as a main-transcript user_message.created row. Background-task wake projection uses this as a turn-only system-user message in Turn activity.",
          "$ref": "#/$defs/nonEmptyString"
        },
        "task_id": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "finalAnswer": {
      "description": "The durable assistant item(s) that make up the user-visible final answer for a completed turn. Projection must use these Tank timeline IDs instead of inferring finality from provider item ordering.",
      "type": "object",
      "additionalProperties": false,
      "required": ["timeline_ids"],
      "properties": {
        "timeline_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "provider_item_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "turnCompletedPayload": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "reason": { "type": "string" },
        "usage": {},
        "error": {},
        "final_answer": { "$ref": "#/$defs/finalAnswer" },
        "background_work_pending": {
          "type": "boolean",
          "description": "Harness observation stamped by a runner: true when the agent still has background work in flight at this terminal, so the user-facing turn is mid-flight, not an end. The activity fold folds a would-be-ready terminal carrying this to the non-summoning scheduled status."
        }
      }
    },
    "turnUsagePayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["usage"],
      "properties": {
        "usage": {
          "type": "object",
          "additionalProperties": true
        },
        "usage_observation": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "sessionStatusPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "text"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["loading", "ready", "failed"]
        },
        "text": { "$ref": "#/$defs/nonEmptyString" },
        "reason": { "type": "string" },
        "session_status": { "type": "string" }
      }
    },
    "itemPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind"],
      "properties": {
        "kind": { "$ref": "#/$defs/nonEmptyString" },
        "outcome": { "$ref": "#/$defs/itemOutcome" }
      }
    },
    "itemOutcome": {
      "description": "Provider-neutral item outcome. Event type is lifecycle/plumbing; this outcome records completed-but-unsuccessful tool results without escalating the item to item.failed.",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["ok", "result_failed", "execution_failed"]
        },
        "reason": {
          "type": "string",
          "enum": [
            "claude_tool_result_is_error",
            "codex_item_status_failed",
            "exit_code",
            "provider_item_error"
          ]
        },
        "code": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string", "minLength": 1 }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "ok" } }, "required": ["kind"] },
          "then": { "not": { "required": ["reason"] } }
        },
        {
          "if": { "properties": { "kind": { "enum": ["result_failed", "execution_failed"] } }, "required": ["kind"] },
          "then": { "required": ["reason"] }
        }
      ]
    },
    "shellTaskPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "task_id", "status"],
      "properties": {
        "kind": { "const": "shell_task" },
        "task_id": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "$ref": "#/$defs/nonEmptyString" },
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "tool_use_id": { "type": "string", "minLength": 1 },
        "last_tool_name": { "type": "string" },
        "error": {}
      }
    },
    "scheduledWakeupPayload": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "wakeup_id", "status", "due_at"],
      "properties": {
        "kind": { "const": "scheduled_wakeup" },
        "wakeup_id": { "$ref": "#/$defs/nonEmptyString" },
        "status": {
          "type": "string",
          "enum": ["scheduled", "claiming", "fired", "failed", "cancelled"]
        },
        "prompt": { "type": "string" },
        "scheduled_turn_id": { "type": "string" },
        "provider_item_id": { "type": "string" },
        "scheduled_at": { "type": "string", "format": "date-time" },
        "due_at": { "type": "string", "format": "date-time" },
        "attempt_count": { "type": "integer", "minimum": 0 },
        "fired_turn_id": { "type": "string" },
        "last_error": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "user_message.created" } }, "required": ["type"] },
      "then": {
        "required": ["turn_id", "timeline_id", "client_nonce", "payload"],
        "properties": {
          "actor": { "const": "user" },
          "source": { "const": "tank" },
          "payload": { "$ref": "#/$defs/userMessagePayload" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "assistant_message.created" } }, "required": ["type"] },
      "then": {
        "required": ["turn_id", "timeline_id", "payload"],
        "properties": {
          "actor": { "const": "assistant" },
          "payload": { "$ref": "#/$defs/assistantMessagePayload" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "turn.submitted" } }, "required": ["type"] },
      "then": {
        "required": ["turn_id", "client_nonce", "payload"],
        "properties": {
          "actor": { "const": "runner" },
          "source": { "const": "tank" },
          "payload": { "$ref": "#/$defs/statusPayload" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["turn.claimed", "turn.started", "turn.usage", "turn.completed", "turn.failed", "turn.interrupted", "turn.awaiting_input"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["turn_id"],
        "properties": {
          "actor": { "const": "runner" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "context.compacted" } }, "required": ["type"] },
      "then": {
        "required": ["turn_id", "payload"],
        "properties": {
          "actor": { "const": "runner" },
          "payload": {
            "type": "object",
            "required": ["trigger"],
            "properties": {
              "trigger": { "enum": ["auto", "manual"] },
              "pre_tokens": { "type": "number", "minimum": 0 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "turn.usage" } }, "required": ["type"] },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": { "$ref": "#/$defs/turnUsagePayload" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "turn.completed" } }, "required": ["type"] },
      "then": {
        "properties": {
          "payload": { "$ref": "#/$defs/turnCompletedPayload" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "turn.command_failed" }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["turn_id", "payload"],
        "properties": {
          "actor": { "const": "system" },
          "source": { "const": "tank" },
          "payload": {
            "type": "object",
            "required": ["reason"],
            "properties": {
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "turn.interrupt_requested" } },
        "required": ["type"]
      },
      "then": {
        "required": ["turn_id"],
        "properties": {
          "actor": { "const": "system" },
          "source": { "const": "tank" }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "session.status" } },
        "required": ["type"]
      },
      "then": {
        "required": ["timeline_id", "payload"],
        "properties": {
          "actor": { "const": "system" },
          "source": { "const": "tank" },
          "payload": { "$ref": "#/$defs/sessionStatusPayload" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["item.started", "item.completed", "item.failed"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["turn_id", "timeline_id", "payload"],
        "properties": {
          "payload": { "$ref": "#/$defs/itemPayload" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["shell_task.started", "shell_task.updated", "shell_task.exited"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "required": ["turn_id", "timeline_id", "task_id", "payload"],
        "properties": {
          "actor": { "const": "tool" },
          "payload": { "$ref": "#/$defs/shellTaskPayload" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "scheduled_wakeup.updated" } }, "required": ["type"] },
      "then": {
        "required": ["timeline_id", "client_nonce", "payload"],
        "properties": {
          "actor": { "const": "system" },
          "source": { "const": "tank" },
          "payload": { "$ref": "#/$defs/scheduledWakeupPayload" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "ci_status.updated" } }, "required": ["type"] },
      "then": {
        "required": ["timeline_id", "client_nonce", "payload"],
        "properties": {
          "actor": { "const": "system" },
          "source": { "const": "tank" },
          "payload": {
            "type": "object",
            "required": ["kind", "pr_url", "state"],
            "properties": {
              "kind": { "const": "ci_status" },
              "state": { "enum": ["merged", "ready", "failed", "conflict"] }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "test_provision.updated" } }, "required": ["type"] },
      "then": {
        "required": ["timeline_id", "client_nonce", "payload"],
        "properties": {
          "actor": { "const": "system" },
          "source": { "const": "tank" },
          "payload": {
            "type": "object",
            "required": ["kind", "phase", "text"],
            "properties": {
              "kind": { "const": "test_provision" },
              "phase": { "enum": ["creating", "validating", "waiting", "ready", "error"] }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "turn.awaiting_input" } }, "required": ["type"] },
      "then": {
        "required": ["payload"],
        "properties": {
          "payload": { "$ref": "#/$defs/awaitingInputPayload" }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "turn.awaiting_input.invocation" } }, "required": ["type"] },
      "then": {
        "required": ["turn_id", "timeline_id", "payload"],
        "properties": {
          "actor": { "const": "runner" },
