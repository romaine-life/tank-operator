{
  "name": "tank-codex-runner",
  "private": true,
  "version": "0.1.0",
  "description": "Long-lived pod-side runner that drives @openai/codex-sdk and publishes canonical events to the session bus.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "start": "node dist/index.js",
    "test": "node --test dist/"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nats-io/jetstream": "^3.4.0",
    "@nats-io/transport-node": "^3.4.0",
    "@openai/codex-sdk": "^0.130.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
