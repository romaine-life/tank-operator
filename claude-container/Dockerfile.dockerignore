# BuildKit picks this up when -f claude-container/Dockerfile is used.
#
# Denylist-shaped: exclude things claude-container/Dockerfile does not
# COPY from (other build contexts in the repo, standard cruft). New
# files added under claude-container/ work without dockerignore edits;
# the failure mode of forgetting to exclude something is a slightly
# larger context, not a missing-file build break.

# Standard cruft
.git
.github
**/__pycache__
**/*.egg-info
**/node_modules
**/.venv
**/.pytest_cache
**/dist
**/.vite
*.log

# Other Dockerfile contexts in this repo — not used by claude-container's
# build, so don't bloat the context.
agent-container
api-proxy
backend
frontend
infra
k8s
k8s-sessions
scripts

# Top-level non-source
.dockerignore
.gitattributes
.gitignore
CLAUDE.md
AGENTS.md
README.md
