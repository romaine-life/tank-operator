{
  "name": "tank-operator-desktop",
  "private": true,
  "version": "0.1.3",
  "description": "Desktop shell for Tank Operator.",
  "author": "tank-operator",
  "license": "UNLICENSED",
  "homepage": "https://tank.romaine.life",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --dir",
    "dist": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "life.romaine.tank-operator",
    "productName": "Tank Operator",
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/after-pack.js",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "icon": "assets/app-icon",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/app-icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "Tank-Operator-Setup-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tank Operator",
      "include": "build/installer.nsh",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "assets/app-icon.ico",
      "uninstallerIcon": "assets/app-icon.ico"
    }
  }
}
