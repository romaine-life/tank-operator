#!/bin/sh
repo_root=$(git rev-parse --show-toplevel 2>/dev/null || printf '%s\n' "")
hook="$repo_root/k8s/session-config/agent-pre-push-hook.sh"
if [ -f "$hook" ]; then
  exec sh "$hook" "$@"
fi

cat <<'EOF'

[tank-agent] Direct git push is disabled outside the agent-egress proxy (the
wall). Tank routes every session's GitHub traffic through the wall, which mints
the credential server-side, records the push, and — for restricted sessions —
rejects pushes to main and merges. With the wall enabled, `git push` and
`gh pr create|edit|ready|comment` just work; this defensive block only fires in
a worktree set up without the wall, where there is no governed path.

EOF
exit 1
