#!/bin/sh

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || printf '%s\n' "")
if [ -f /opt/tank/session-config/agent-post-commit-hook.sh ]; then
  exec sh /opt/tank/session-config/agent-post-commit-hook.sh "$@"
fi
if [ -f "$repo_root/k8s/session-config/agent-post-commit-hook.sh" ]; then
  exec sh "$repo_root/k8s/session-config/agent-post-commit-hook.sh" "$@"
fi

cat <<'EOF'

[tank-agent] Local commit created, but the Tank auto-publish hook script was
not available. In a Tank session, every commit must be published through the
Tank MCP publish_current_head tool and watched until CI is green and mergeable.

EOF
